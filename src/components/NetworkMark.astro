---
/*
  Signature mark — a network/node graph suspended inside a "J", echoing the
  Jean logo concept. Used as the nav logo and favicon source. Pure SVG, inherits
  `currentColor`, so it tints with the accent token automatically.
*/
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 32 32"
  fill="none"
  role="img"
  aria-label="Network mark"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- the J stroke -->
  <path
    d="M21 6v12a6 6 0 0 1-6 6 6 6 0 0 1-6-6"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    opacity="0.35"
  />
  <!-- network edges -->
  <path d="M21 6 11 12M11 12l6 7M17 19l4-6M11 12l6 0" stroke="currentColor" stroke-width="1.2" opacity="0.55" />
  <!-- nodes -->
  <circle cx="21" cy="6" r="2.4" fill="currentColor" />
  <circle cx="11" cy="12" r="2" fill="currentColor" />
  <circle cx="17" cy="19" r="2" fill="currentColor" />
  <circle cx="21" cy="13" r="1.6" fill="currentColor" opacity="0.8" />
</svg>
