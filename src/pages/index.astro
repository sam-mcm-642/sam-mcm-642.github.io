---
import BaseLayout from '../layouts/BaseLayout.astro';
import NetworkMotif from '../components/NetworkMotif.astro';
import { site, socials } from '../data/site';
import { Image } from 'astro:assets';
import me from '../assets/me.jpg';

/*
  Landing page — deliberately minimal (brief §5): the positioning story, a
  photo, contact links. NO project cards here; projects live behind the nav
  dropdown / index. The design carries the page, so keep copy tight.

  PHOTO: drop a portrait at `src/assets/me.jpg` and switch the placeholder block
  below for an <Image>. Left as a styled placeholder so the site builds without it.
*/
---

<BaseLayout description={site.tagline}>
  <section class="relative overflow-hidden">
    <!-- network motif backdrop -->
    <NetworkMotif
      class="pointer-events-none absolute inset-0 h-full w-full text-accent opacity-[0.10] dark:opacity-[0.14]"
    />

    <div class="relative mx-auto grid max-w-5xl items-center gap-10 px-5 py-20 sm:py-28 md:grid-cols-[1.4fr_1fr]">
      <div class="reveal is-visible flex flex-col gap-6">
        <p class="font-display text-sm font-medium uppercase tracking-[0.2em] text-accent">
          Machine learning · Data science
        </p>
        <h1 class="font-display text-4xl font-bold leading-[1.1] tracking-tight sm:text-5xl">
          {site.name}
        </h1>
        <p class="max-w-xl text-lg leading-relaxed text-muted">
          {site.intro}
        </p>

        <div class="flex flex-wrap items-center gap-3 pt-2">
          <a
            href={`mailto:${site.email}`}
            class="rounded-full bg-accent px-5 py-2.5 text-sm font-medium text-accent-fg transition-opacity hover:opacity-90"
          >
            Get in touch
          </a>
          <a
            href="/projects"
            class="rounded-full border border-border px-5 py-2.5 text-sm font-medium transition-colors hover:bg-accent-soft"
          >
            View projects
          </a>
          {
            socials
              .filter((s) => s.label !== 'Email')
              .map((s) => (
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm font-medium text-muted transition-colors hover:text-text"
                >
                  {s.label}
                </a>
              ))
          }
        </div>
      </div>

      <!-- Portrait slot -->
      <div class="reveal is-visible mx-auto w-full max-w-[260px]">
        <div class="relative aspect-square overflow-hidden rounded-2xl border border-border">
          <Image
            src={me}
            alt={site.name}
            width={520}
            height={520}
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
