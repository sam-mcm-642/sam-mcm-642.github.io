---
import BaseLayout from '../layouts/BaseLayout.astro';
import NetworkMotif from '../components/NetworkMotif.astro';
---

<BaseLayout title="Page not found" description="That page doesn't exist.">
  <section class="relative overflow-hidden">
    <NetworkMotif class="pointer-events-none absolute inset-0 h-full w-full text-accent opacity-[0.10]" />
    <div class="relative mx-auto flex max-w-3xl flex-col items-center gap-5 px-5 py-28 text-center">
      <p class="font-display text-6xl font-bold tracking-tight text-accent">404</p>
      <h1 class="font-display text-2xl font-semibold">This page isn't on the map</h1>
      <p class="text-muted">The page you're looking for doesn't exist or has moved.</p>
      <div class="flex gap-3 pt-2">
        <a
          href="/"
          class="rounded-full bg-accent px-5 py-2.5 text-sm font-medium text-accent-fg transition-opacity hover:opacity-90"
        >
          Home
        </a>
        <a
          href="/projects"
          class="rounded-full border border-border px-5 py-2.5 text-sm font-medium transition-colors hover:bg-accent-soft"
        >
          Projects
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
